# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pizzaapp

# JWT (use separate random values of at least 64 characters)
ACCESS_TOKEN_SECRET=replace_with_a_random_secret_at_least_64_characters_long_aaaaaaaa
REFRESH_TOKEN_SECRET=replace_with_a_different_random_secret_at_least_64_chars_bbbb
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Email (Gmail App Password)
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Razorpay Test Mode
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# URLs and administrator identity
CLIENT_URL=http://localhost:5173
ADMIN_EMAIL=admin@yourdomain.com

# Vite client (omit /api from the URL)
VITE_API_URL=http://localhost:5000
